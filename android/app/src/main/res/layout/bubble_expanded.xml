<?xml version="1.0" encoding="utf-8"?>
<!-- The expanded balloon: the control web UI + quick actions, floating over apps.
     Root is match_parent so it fills the (resizable) overlay window; the footer holds a
     drag-to-resize grip. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFFFF"
    android:elevation="12dp">

    <LinearLayout
        android:id="@+id/bubbleHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1565C0"
        android:gravity="center_vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:text="@string/app_name" />

        <Button
            android:id="@+id/bubbleStop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="@string/btn_cast_stop" />

        <Button
            android:id="@+id/bubbleCollapse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="0dp"
            android:text="—" />
    </LinearLayout>

    <WebView
        android:id="@+id/bubbleWeb"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- footer: drag the grip to resize the window -->
    <TextView
        android:id="@+id/bubbleResize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:padding="6dp"
        android:textSize="16sp"
        android:textColor="#1565C0"
        android:background="#EEEEEE"
        android:text="⤡" />
</LinearLayout>
